# Supabase — Transaction Pooler (porta 6543)
# Settings → Database → Connection string → URI → Transaction pooler
DATABASE_URL="postgresql://postgres.[ref]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

# Amazon Associates affiliate tag — leave empty to omit the tag from URLs
ASSOCIATE_TAG="groovesnrecor-20"

# Last.fm API key — used to enrich artists with genre tags
# Create one at https://www.last.fm/api/account/create (free)
LASTFM_API_KEY=""

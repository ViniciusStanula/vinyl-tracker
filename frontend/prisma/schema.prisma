generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Disco {
  id        String   @id @default(uuid())
  asin      String   @unique
  titulo    String
  artista   String
  slug      String   @unique
  estilo    String?
  imgUrl    String?
  url       String
  rating      Decimal? @db.Decimal(3, 1)
  reviewCount Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  precos HistoricoPreco[]

  @@index([artista])
  @@index([titulo])
  @@index([estilo])
  @@index([slug])
}

model HistoricoPreco {
  id          String   @id @default(uuid())
  discoId     String
  disco       Disco    @relation(fields: [discoId], references: [id], onDelete: Cascade)
  precoBrl    Decimal  @db.Decimal(10, 2)
  capturadoEm DateTime @default(now())

  @@index([discoId, capturadoEm(sort: Desc)])
  @@index([capturadoEm(sort: Desc)])
}
